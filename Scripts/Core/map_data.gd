class_name MapData

const MAPS_DIR = "res://maps/"

const TYPE_MAP = {
	0: GridManager.CellType.FLOOR,
	1: GridManager.CellType.FLOOR_HIGH,
	2: GridManager.CellType.RIVER_WATER,
	3: GridManager.CellType.RIVER_SHORE,
	4: GridManager.CellType.BRIDGE,
	5: GridManager.CellType.SANCTUM,
	6: GridManager.CellType.HAZARD_COLLAPSE,
	7: GridManager.CellType.HAZARD_TRAP,
	8: GridManager.CellType.BLOCKED,
	9: GridManager.CellType.EMPTY,
}

static func load_all() -> Array[Dictionary]:
	var maps: Array[Dictionary] = []
	var dir = DirAccess.open(MAPS_DIR)
	if dir == null:
		push_error("MapData: maps/ directory not found")
		return maps
	dir.list_dir_begin()
	var fname = dir.get_next()
	while fname != "":
		if fname.ends_with(".json"):
			var map = _load_map_file(MAPS_DIR + fname)
			if map != null:
				maps.append(map)
		fname = dir.get_next()
	return maps

static func _load_map_file(path: String) -> Dictionary:
	var file = FileAccess.open(path, FileAccess.READ)
	if file == null:
		return {}
	var json = JSON.new()
	var err = json.parse(file.get_as_text())
	file.close()
	if err != OK:
		push_error("MapData: failed to parse " + path)
		return {}
	var data = json.data
	var cells: Dictionary = {}
	for key in data["cells"]:
		var parts = key.split(",")
		var pos = Vector2i(int(parts[0]), int(parts[1]))
		var type_int = int(data["cells"][key])
		cells[pos] = TYPE_MAP.get(type_int, GridManager.CellType.FLOOR)
	return {
		"name": data.get("name", "Unknown"),
		"cells": cells
	}




















